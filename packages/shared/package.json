{
  "name": "@a-data-agent/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types, constants, and utility functions for the a-data-agent frontend apps. Consumed by apps/web and any future apps (e.g. apps/admin).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./lib": {
      "types": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(no lint configured for @a-data-agent/shared yet)\"",
    "build": "echo \"(no build step — package is consumed as TS source via transpilePackages)\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@types/node": "^20",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependenciesMeta": {
    "clsx": {
      "optional": true
    },
    "tailwind-merge": {
      "optional": true
    }
  }
}
